{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    // Environment setup & latest features
    "lib": [
      "ESNext"
    ],
    "target": "ESNext",
    "module": "ESNext",
    "composite": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    // Best practices
    "strict": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": [
      "bun-types"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@repo/database": [
        "../packages/db/dist/client.d.ts"
      ],
      "@lib/*": [
        "./src/lib/*"
      ],
      "@services/*": [
        "./src/services/*"
      ],
      "@types/*": [
        "./src/types/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@helpers/*": [
        "./src/helpers/*"
      ],
      "@routes/*": [
        "./src/routes/*"
      ],
      "@middleware/*": [
        "./src/middleware/*"
      ],
      "@shared/*": [
        "../shared/*"
      ]
    },
    // Output settings
    "declaration": true,
    "outDir": "dist",
    "noEmit": false,
    "rootDir": "./",
    "emitDecoratorMetadata": true,
  },
  "include": [
    "src/**/*",
    "eslint.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CursoStatus {
  activo
  inactivo
}

enum OrderStatus {
  PENDING
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  POS
  ONLINE
  YAPE
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum RoleAccess {
  SALES_REP
  MARKETING
  SALES_SUPERVISOR
  ADMIN
  COLLECTIONS
}

enum CampaingStatus {
  ACTIVE
  INACTIVE
  PAUSED
}

enum EditionStatus {
  IN_PROGRESS
  COMPLETED
  OPEN
  SCHEDULED
  DRAFT
  CANCELLED
}

enum SalesStatus {
  DRAFT
  PUBLISHED
  ON_SALE
  COMPLETED
  CANCELLED
}

enum CampaingPlatform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  WEBSITE
}

enum LeadOriginSource {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  WHATSAPP
  WEBSITE
}

enum CampaignMemberStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  ATTEMPTED_CONTACT
  FOLLOW_UP
  ON_HOLD
  WON
  LOST
}

enum Gender {
  MALE
  FEMALE
  NOT_SPECIFIED
}

model Role {
  id          String     @id @default(uuid()) @db.Char(36)
  name        RoleAccess @unique
  description String?
  is_active   Boolean    @default(true)
  users       User[]
}

model SellerProfile {
  id                String   @id @default(uuid()) @db.Char(36)
  user_id           String   @unique
  sales_target      Int      @default(0)
  max_discount      Decimal? @default(0)
  assigned_campaing String

  user            User              @relation(fields: [user_id], references: [id])
  campaignMembers CampaignMember[]
  orders          Order[]           @relation("SELLER_ORDERS")
  LeadInteraction LeadInteraction[]
  campaigns       CampaignSeller[]
}

model CampaignSeller {
  id          String @id @default(uuid()) @db.Char(36)
  campaign_id String
  seller_id   String

  campaign Campaing      @relation(fields: [campaign_id], references: [id])
  seller   SellerProfile @relation(fields: [seller_id], references: [id])

  assigned_at DateTime @default(now())

  @@unique([campaign_id, seller_id])
}

// add more fields for this role
model MarketingProfile {
  id      String @id @default(uuid()) @db.Char(36)
  user_id String @unique

  user User @relation(fields: [user_id], references: [id])
}

model User {
  id          String            @id @default(uuid()) @db.Char(36)
  first_name  String
  middle_name String
  last_name   String
  email       String?           @unique
  cellphone   String?           @db.Char(9)
  role_id     String
  is_active   Boolean           @default(true)
  password    String
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  role        Role              @relation(fields: [role_id], references: [id])
  marketing   MarketingProfile?
  seller      SellerProfile?
}

enum PhoneType {
  WHATSAPP
  TELEPHONE
}

model LeadPhone {
  id      String    @id @default(uuid()) @db.Char(36)
  number  String
  type    PhoneType
  lead_id String

  lead Lead @relation(fields: [lead_id], references: [id])
}

model CampaignMember {
  id          String               @id @default(uuid()) @db.Char(36)
  lead_id     String
  campaing_id String
  status      CampaignMemberStatus @default(NEW)
  assigned_to String
  source      LeadOriginSource
  created_at  DateTime             @default(now())
  updated_at  DateTime             @updatedAt
  is_primary  Boolean              @default(false)

  lead             Lead              @relation(fields: [lead_id], references: [id])
  campaing         Campaing          @relation(fields: [campaing_id], references: [id])
  seller           SellerProfile?    @relation(fields: [assigned_to], references: [id])
  leadInteractions LeadInteraction[]

  @@unique([lead_id, campaing_id])
  @@index([status])
  @@index([assigned_to])
}

enum LeadStatus {
  ACTIVE
  INACTIVE
}

enum MoodleStudentStatus {
  ACTIVE
  SUSPENDED
}

model CustomerProfile {
  id                 String              @id @default(uuid()) @db.Char(36)
  lead_id            String              @unique
  moodle_user_name   String
  moodle_user_id     Int?                @unique
  moodle_user_status MoodleStudentStatus @default(ACTIVE)
  password           String

  lead Lead @relation(fields: [lead_id], references: [id])
}

model Lead {
  id                  String     @id @default(uuid()) @db.Char(36)
  first_name          String
  middle_name         String
  last_name           String
  profession          String?
  gender              Gender?
  address             String?
  second_address      String?
  email               String     @unique
  secondary_email     String?
  dni                 String?    @unique @db.Char(8)
  lead_status         LeadStatus @default(ACTIVE)
  primary_campaign_id String?
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  //relations
  phones              LeadPhone[]
  orders              Order[]
  interactions        LeadInteraction[]
  campaignsEngaging   CampaignMember[]
  customerProfile     CustomerProfile?
  leadPrimaryCampaing Campaing?         @relation("PrimaryCampaign", fields: [primary_campaign_id], references: [id])
}

enum InteractionType {
  WEBSITE_FORM
  SELL
  WHATSAPP
  EMAIL
  MEETING
  CALL
}

model LeadInteraction {
  id          String          @id @default(uuid()) @db.Char(36)
  lead_id     String
  notes       String
  created_by  String?
  campaing_id String
  type        InteractionType

  lead           Lead           @relation(fields: [lead_id], references: [id])
  campaignMember CampaignMember @relation(fields: [campaing_id], references: [id])
  seller         SellerProfile? @relation(fields: [created_by], references: [id])
}

model Tasks {
  id      String @id @default(uuid()) @db.Char(36)
  title   String
  content String @db.Text()
}

model Course {
  id          String    @id @default(uuid()) @db.Char(36)
  name        String
  description String?
  classes_number Int
  image_url   String?
  code        String    @db.Char(7)
  editions    Edition[]
}

model Campaing {
  id             String           @id @default(uuid()) @db.Char(36)
  campaing_name  String
  initial_budget Decimal          @db.Decimal(10, 2)
  total_spent    Decimal?         @db.Decimal(10, 2)
  status         CampaingStatus
  start_date     DateTime
  end_date       DateTime?
  platform       CampaingPlatform
  is_organic     Boolean
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  edition_id     String           @unique

  members CampaignMember[]
  leads   Lead[]           @relation("PrimaryCampaign")
  edition Edition          @relation(fields: [edition_id], references: [id])
  sellers CampaignSeller[]
}

model Modality {
  id       String    @id @default(uuid()) @db.Char(36)
  name     String    @unique
  editions Edition[]
}

enum WeekDays {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ScheduleType {
  REGULAR // the default recurring schedule
  OVERRIDE // a temporary schedule for a specific period
}

model EditionSchedule {
  id          String                @id @default(uuid()) @db.Char(36)
  edition_id  String
  day_of_week WeekDays
  type        ScheduleType          @default(REGULAR) // REGULAR applies for the full duration of the edition
  // fields just for OVERRIDE blocks
  valid_from  DateTime?             @db.Date
  valid_until DateTime?             @db.Date
  slots       EditionScheduleSlot[]
  created_at  DateTime              @default(now())
  updated_at  DateTime              @updatedAt

  edition Edition @relation(fields: [edition_id], references: [id])

  @@index([edition_id])
}

model EditionScheduleSlot {
  id          String @id @default(uuid()) @db.Char(36)
  schedule_id String
  start_time  String // "HH:MM" in 24h — avoids timezone drift on TIME columns
  end_time    String // "HH:MM" in 24h

  schedule EditionSchedule @relation(fields: [schedule_id], references: [id], onDelete: Cascade)

  @@index([schedule_id])
}

enum DurationUnit {
  WEEKS
  MONTHS
}

model Edition {
  id             String   @id @default(uuid()) @db.Char(36)
  course_id      String
  edition_number Int
  start_date     DateTime @db.Date
  hours_amount Int
  classes_number Int // you cand define them or take them from the course table
  duration_value          Int 
  duration_unit DurationUnit
  end_date         DateTime      @db.Date
  modality_id      String
  moodle_course_id Int?          @unique
  teacher_fullname String
  meet_link        String?  // optional: PACKED modalities do not have one
  edition_status   EditionStatus @default(DRAFT)
  edition_code     String        @unique @db.Char(12) //generated based on the course-code + year + ednumber

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  course     Course   @relation(fields: [course_id], references: [id])
  modality   Modality @relation(fields: [modality_id], references: [id])
  productItems     ProductItem[]
  campaing         Campaing?
  schedules EditionSchedule[]
}

model ProductItem {
  id         String @id @default(uuid()) @db.Char(36)
  edition_id String
  product_id String

  edition Edition @relation(fields: [edition_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])
}

model Product {
  id                  String      @id @default(uuid()) @db.Char(36)
  name                String // you can write a new name or define it from the course and edition.
  slug                String?
  description         String?
  short_description   String?
  category            String
  cash_price          Decimal     @db.Decimal(10, 2)
  installment_price   Decimal     @db.Decimal(10, 2)
  discount_price      Decimal?    @default(0) @db.Decimal(10, 2)
  discount_expires_at DateTime?
  sales_status        SalesStatus @default(DRAFT)
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt

  productItems   ProductItem[]
  orders_details OrderDetail[]
}

model Order {
  id           String      @id @default(uuid()) @db.Char(36)
  lead_id      String
  generated_by String?
  sub_total    Decimal     @db.Decimal(10, 2)
  total_amount Decimal     @db.Decimal(10, 2)
  discount     Decimal     @default(0) @db.Decimal(10, 2)
  order_status OrderStatus @default(PENDING)
  order_code   String      @unique @db.Char(7)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  lead   Lead           @relation(fields: [lead_id], references: [id])
  seller SellerProfile? @relation("SELLER_ORDERS", fields: [generated_by], references: [user_id])

  orderDetails OrderDetail[]
  paymentPlans PaymentPlan[]
  payments     Payment[]

  // indexes
  @@index([lead_id])
  @@index([order_status])
}

model OrderDetail {
  id            String  @id @default(uuid()) @db.Char(36)
  product_id    String
  price         Decimal @db.Decimal(10, 2)
  order_id      String
  discount_code String? @db.Char(7)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  product    Product  @relation(fields: [product_id], references: [id])
  order      Order    @relation(fields: [order_id], references: [id])
}

// TODO add fields and a model to manage cuotas and cash payments
enum PaymentType {
  FULL
  INSTALLMENTS
}

//regiter payment transactions
model Payment {
  id                   String        @id @default(uuid()) @db.Char(36)
  order_id             String
  scheduled_payment_id String?
  payment_date         DateTime
  amount               Decimal       @db.Decimal(10, 2)
  payment_method       PaymentMethod
  payment_status       PaymentStatus
  type                 PaymentType
  payment_receipt      String?
  currency             String?       @db.Char(3)
  transaccion_id       String? // from payment gateway
  created_at           DateTime      @default(now())
  updated_at           DateTime      @updatedAt

  schedulePayment ScheduledPayment? @relation(fields: [scheduled_payment_id], references: [id])
  order           Order             @relation(fields: [order_id], references: [id])

  @@index([payment_status])
}

enum PaymentPlanStatus {
  COMPLETED
  PENDING
  CANCELLED
}

model PaymentPlan {
  id                 String            @id @default(uuid()) @db.Char(36)
  total_installments Int
  order_id           String
  total_amount       Decimal           @db.Decimal(10, 2)
  start_date         DateTime
  status             PaymentPlanStatus @default(PENDING)

  order        Order              @relation(fields: [order_id], references: [id])
  installments ScheduledPayment[]

  @@index([order_id])
}

enum InstallmentStatus {
  PARTIALLY_PAID
  PAID
  OVERDUE
  PENDING
}

model ScheduledPayment {
  id              String            @id @default(uuid()) @db.Char(36)
  due_date        DateTime
  due_amount      Decimal           @db.Decimal(10, 2)
  payment_plan_id String
  number          Int               @default(1)
  status          InstallmentStatus @default(PENDING)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  payment_plan PaymentPlan @relation(fields: [payment_plan_id], references: [id])
  payments     Payment[]

  @@unique([payment_plan_id, number])
}

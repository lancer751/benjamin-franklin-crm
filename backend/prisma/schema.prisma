generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CursoStatus {
  activo
  inactivo
}

enum OrderStatus {
  PENDING
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  POS
  ONLINE
  YAPE
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum RoleAccess {
  SALES_REP
  MARKETING
  SALES_SUPERVISOR
  ADMIN
  COLLECTIONS
}

enum CampaingStatus {
  ACTIVE
  INACTIVE
  PAUSED
}

enum EditionStatus {
  IN_PROGRESS
  COMPLETED
  OPEN
  SCHEDULED
  DRAFT
  CANCELLED
}

enum SalesStatus {
  DRAFT
  PUBLISHED
  ON_SALE
  COMPLETED
  CANCELLED
}

enum CampaingPlatform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  WEBSITE
}

enum LeadOriginSource {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  WHATSAPP
  WEBSITE
}

enum CampaignMemberStatus {
  NEW
  CONTACTED
  ATTEMPTED_CONTACT
  QUALIFIED
  UNQUALIFIED
  IN_PROGRESS
  NEGOTIATION
  PROPOSAL_SENT
  WON
  LOST
  REJECTED
  FOLLOW_UP
  ON_HOLD
}

enum Gender {
  MALE
  FEMALE
  NOT_SPECIFIED
}

model Role {
  id          String     @id @default(uuid()) @db.Char(36)
  name        RoleAccess @unique
  description String?
  is_active   Boolean    @default(true)
  users       User[]
}

model SellerProfile {
  id           String   @id @default(uuid()) @db.Char(36)
  user_id      String   @unique
  sales_target Int      @default(0)
  max_discount Decimal? @default(0)

  user            User              @relation(fields: [user_id], references: [id])
  campaingMembers CampaingMember[]
  orders          Order[]           @relation("SELLER_ORDERS")
  LeadInteraction LeadInteraction[]
}

// add more fields for this role
model MarketingProfile {
  id      String @id @default(uuid()) @db.Char(36)
  user_id String @unique

  user User @relation(fields: [user_id], references: [id])
}

model User {
  id          String            @id @default(uuid()) @db.Char(36)
  first_name  String
  middle_name String
  last_name   String
  email       String?           @unique
  cellphone   String?           @db.Char(9)
  role_id     String
  is_active   Boolean           @default(true)
  password    String
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  role        Role              @relation(fields: [role_id], references: [id])
  marketing   MarketingProfile?
  seller      SellerProfile?
}

enum PhoneType {
  WHATSAPP
  TELEPHONE
}

model LeadPhone {
  id      String    @id @default(uuid()) @db.Char(36)
  number  String
  type    PhoneType
  lead_id String

  lead Lead @relation(fields: [lead_id], references: [id])
}

model CampaingMember {
  id          String               @id @default(uuid()) @db.Char(36)
  lead_id     String
  campaing_id String
  status      CampaignMemberStatus @default(NEW)
  assigned_to String?
  source      LeadOriginSource
  created_at  DateTime             @default(now())
  updated_at  DateTime             @updatedAt
  is_primary  Boolean              @default(false)

  lead             Lead              @relation(fields: [lead_id], references: [id])
  campaing         Campaing          @relation(fields: [campaing_id], references: [id])
  seller           SellerProfile?    @relation(fields: [assigned_to], references: [id])
  leadInteractions LeadInteraction[]

  @@unique([lead_id, campaing_id])
  @@index([status])
  @@index([assigned_to])
}

enum LeadStatus {
  ACTIVE
  INACTIVE
}

enum LeadStage {
  PROSPECT
}

model Lead {
  id                  String     @id @default(uuid()) @db.Char(36)
  first_name          String
  middle_name         String
  last_name           String
  profession          String?
  gender              Gender?
  address             String?
  second_address      String?
  email               String     @unique
  secondary_email     String?
  dni                 String?    @unique @db.Char(8)
  moodle_user_id      Int?       @unique
  lead_status         LeadStatus @default(ACTIVE)
  primary_campaign_id String?
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  //relations
  phones              LeadPhone[]
  orders              Order[]
  leadInteraction     LeadInteraction[]
  campaingMember      CampaingMember[]
  leadPrimaryCampaing Campaing?         @relation("PrimaryCampaign", fields: [primary_campaign_id], references: [id])
}

enum InteractionType {
  WEBSITE_FORM
  SELL
  WHATSAPP
  EMAIL
  MEETING
  CALL
}

model LeadInteraction {
  id          String          @id @default(uuid()) @db.Char(36)
  lead_id     String
  notes       String
  created_by  String?
  campaing_id String
  type        InteractionType

  lead           Lead           @relation(fields: [lead_id], references: [id])
  campaingMember CampaingMember @relation(fields: [campaing_id], references: [id])
  seller         SellerProfile? @relation(fields: [created_by], references: [id])
}

model Tasks {
  id      String @id @default(uuid()) @db.Char(36)
  title   String
  content String @db.Text()
}

model Course {
  id          String    @id @default(uuid()) @db.Char(36)
  name        String
  description String?
  image_url   String?
  code        String    @db.Char(7)
  editions    Edition[]
}

model Campaing {
  id             String           @id @default(uuid()) @db.Char(36)
  campaing_name  String
  initial_budget Decimal          @db.Decimal(10, 2)
  total_spent    Decimal?         @db.Decimal(10, 2)
  status         CampaingStatus
  start_date     DateTime
  end_date       DateTime?
  platform       CampaingPlatform
  is_organic     Boolean
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  edition_id     String           @unique

  CampaingMember CampaingMember[]
  leads          Lead[]           @relation("PrimaryCampaign")
  edition        Edition          @relation(fields: [edition_id], references: [id])
}

model Modality {
  id       String    @id @default(uuid()) @db.Char(36)
  name     String    @unique
  editions Edition[]
}

model Edition {
  id               String        @id @default(uuid()) @db.Char(36)
  course_id        String
  edition_number   Int
  start_date       DateTime      @db.Date
  end_date         DateTime      @db.Date
  modality_id      String
  moodle_course_id Int?          @unique
  teacher_fullname String
  meet_link        String
  edition_status   EditionStatus @default(DRAFT)
  edition_code     String        @unique @db.Char(12) //generated based on the course-code + year + ednumber

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  course     Course   @relation(fields: [course_id], references: [id])
  modality   Modality @relation(fields: [modality_id], references: [id])

  products Product[]
  campaing Campaing?
}

model Product {
  id                  String      @id @default(uuid()) @db.Char(36)
  slug                String?
  description         String?
  short_description   String?
  category            String
  edition_id          String
  cash_price          Decimal     @db.Decimal(10, 2)
  installment_price   Decimal     @db.Decimal(10, 2)
  discount_price      Decimal?    @default(0) @db.Decimal(10, 2)
  discount_expires_at DateTime?
  sales_status        SalesStatus @default(DRAFT)
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt

  edition        Edition       @relation(fields: [edition_id], references: [id])
  orders_details OrderDetail[]
}

model Order {
  id           String      @id @default(uuid()) @db.Char(36)
  lead_id      String
  generated_by String?
  sub_total    Decimal     @db.Decimal(10, 2)
  total_amount Decimal     @db.Decimal(10, 2)
  discount     Decimal     @default(0) @db.Decimal(10, 2)
  order_status OrderStatus @default(PENDING)
  order_code   String      @unique @db.Char(7)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  lead   Lead           @relation(fields: [lead_id], references: [id])
  seller SellerProfile? @relation("SELLER_ORDERS", fields: [generated_by], references: [user_id])

  orderDetails OrderDetail[]
  paymentPlans PaymentPlan[]
  payments Payment[]

  // indexes
  @@index([lead_id])
  @@index([order_status])
}

model OrderDetail {
  id            String  @id @default(uuid()) @db.Char(36)
  product_id    String
  price         Decimal @db.Decimal(10, 2)
  order_id      String
  discount_code String? @db.Char(7)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  product    Product  @relation(fields: [product_id], references: [id])
  order      Order    @relation(fields: [order_id], references: [id])
}

// TODO add fields and a model to manage cuotas and cash payments
enum PaymentType {
  FULL
  INSTALLMENTS
}

//regiter payment transactions
model Payment {
  id                   String        @id @default(uuid()) @db.Char(36)
  order_id String
  scheduled_payment_id String?
  payment_date         DateTime
  amount               Decimal       @db.Decimal(10, 2)
  payment_method       PaymentMethod
  payment_status       PaymentStatus
  type                 PaymentType
  currency             String?       @db.Char(3)
  transaccion_id       String? // from payment gateway
  created_at           DateTime      @default(now())
  updated_at           DateTime      @updatedAt

  schedulePayment ScheduledPayment? @relation(fields: [scheduled_payment_id], references: [id])
  order Order @relation(fields: [order_id], references: [id])

  @@index([payment_status])
}

enum PaymentPlanStatus {
  COMPLETED
  PENDING
  CANCELLED
}

model PaymentPlan {
  id                 String            @id @default(uuid()) @db.Char(36)
  total_installments Int
  order_id           String
  total_amount       Decimal           @db.Decimal(10, 2)
  start_date         DateTime
  status             PaymentPlanStatus @default(PENDING)

  order        Order              @relation(fields: [order_id], references: [id])
  installments ScheduledPayment[]

  @@index([order_id])
}

enum InstallmentStatus {
  PARTIALLY_PAID
  PAID
  OVERDUE
  PENDING
}

model ScheduledPayment {
  id              String            @id @default(uuid()) @db.Char(36)
  due_date        DateTime
  due_amount      Decimal           @db.Decimal(10, 2)
  payment_plan_id String
  number          Int @default(1)
  status          InstallmentStatus @default(PENDING)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  payment_plan PaymentPlan @relation(fields: [payment_plan_id], references: [id])
  payments     Payment[]

  @@unique([payment_plan_id, number])
}

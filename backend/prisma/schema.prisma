generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator zod {
  provider = "prisma-zod-generator"
}

datasource db {
  provider = "mysql"
}

enum CursoStatus {
  activo
  inactivo
}

enum OrderStatus {
  PENDING
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  POS
  ONLINE
  YAPE
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum RoleAccess {
  SALES_REP
  MARKETING
  SALES_SUPERVISOR
  ADMIN
  COLLECTIONS
}

enum CampaingStatus {
  ACTIVE
  INACTIVE
  PAUSED
}

enum EditionStatus {
  IN_PROGRESS
  COMPLETED
  OPEN
  SCHEDULED
  DRAFT
  CANCELLED
}

enum SalesStatus {
  DRAFT
  PUBLISHED
  ON_SALE
  COMPLETED
  CANCELLED
}

enum CampaingPlatform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  WEBSITE
}

enum LeadOriginSource {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  WHATSAPP
  WEBSITE
}

enum LeadStatus {
  NEW
  CONTACTED
  ATTEMPTED_CONTACT
  QUALIFIED
  UNQUALIFIED
  IN_PROGRESS
  NEGOTIATION
  PROPOSAL_SENT
  WON
  LOST
  REJECTED
  FOLLOW_UP
  ON_HOLD
}

enum Gender {
  MALE
  FEMALE
  NOT_SPECIFIED
}

model Role {
  id          String     @id @default(uuid()) @db.Char(36)
  name        RoleAccess
  description String?
  is_active   Boolean    @default(true)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  users       User[]
}

model SellerProfile {
  id           String  @id @default(uuid()) @db.Char(36)
  user_id      String  @unique
  sales_target Int @default(0)
  sales_closed Int? @default(0)
  max_discount Decimal

  user              User                @relation(fields: [user_id], references: [id])
  leads             Lead[]
  orders            Order[]             @relation("SELLER_ORDERS")
  lead_interactions Lead_Interactions[]
}

model MarketingProfile {
  id      String @id @default(uuid()) @db.Char(36)
  user_id String @unique

  user User @relation(fields: [user_id], references: [id])
}

model User {
  id          String            @id @default(uuid()) @db.Char(36)
  first_name  String
  middle_name String
  last_name   String
  email       String            @unique
  cellphone   String            @db.Char(9)
  role_id     String
  is_active   Boolean           @default(true)
  password    String
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  role        Role              @relation(fields: [role_id], references: [id])
  marketing   MarketingProfile?
  seller      SellerProfile?
}

enum PhoneType {
  WHATSAPP
  TELEPHONE
}

model LeadPhone {
  id      String    @id @default(uuid()) @db.Char(36)
  number  String
  type    PhoneType
  lead_id String

  lead Lead @relation(fields: [lead_id], references: [id])
}

model Lead {
  id                 String     @id @default(uuid()) @db.Char(36)
  first_name         String
  middle_name        String
  last_name          String
  profession         String?
  gender             Gender?
  address            String?
  second_address     String?
  email              String     @unique
  secondary_email    String?
  dni                String?    @unique @db.Char(8)
  score Int @default(2)
  moodle_user_id     Int?       @unique
  campaign_id        String?
  assigned_to String?
  source LeadOriginSource
  lead_status        LeadStatus @default(NEW)
  created_at         DateTime   @default(now())
  updated_at         DateTime   @updatedAt

  //relations
  seller            SellerProfile?      @relation(fields: [assigned_to], references: [id])
  phones            LeadPhone[]
  orders            Order[]
  lead_interactions Lead_Interactions[]
  campaing          Campaing?           @relation(fields: [campaign_id], references: [id])

  //indexes
  @@index([assigned_to])
  @@index([lead_status])
}

enum InteractionType {
  website_form
  sell
  whatsapp
  email
  meeting
  call
}

model Lead_Interactions {
  id            String @id @default(uuid()) @db.Char(36)
  lead_id       String
  notes         String
  created_by    String

  lead   Lead          @relation(fields: [lead_id], references: [id])
  seller SellerProfile @relation(fields: [created_by], references: [id])
}

model Tasks {
  id String @id @default(uuid()) @db.Char(36)
  title String
  content String @db.MediumText()
}

model Course {
  id          String    @id @default(uuid()) @db.Char(36)
  name        String
  description String?
  image_url   String?
  code        String    @db.Char(7)
  editions    Edition[]
}

model Campaing {
  id             String   @id @default(uuid()) @db.Char(36)
  campaing_name  String
  initial_budget Decimal  @db.Decimal(10, 2)
  total_spent    Decimal? @db.Decimal(10, 2)

  status     CampaingStatus
  start_date DateTime       @default(now())
  end_date   DateTime?

  platform CampaingPlatform

  is_organic Boolean
  edicion    Edition[]
  leads      Lead[]
}

model Modality {
  id       String    @id @default(uuid()) @db.Char(36)
  nombre   String    @unique
  editions Edition[]
}

model Edition {
  id               String        @id @default(uuid()) @db.Char(36)
  course_id        String
  edition_number   Int
  start_date       DateTime      @db.Date
  end_date         DateTime      @db.Date
  modality_id      String
  moodle_course_id Int?          @unique
  teacher_fullname String
  meet_link        String
  edition_status   EditionStatus @default(DRAFT)
  edition_code     String        @db.Char(7) //generated based on the course-code + year + ednumber
  campaign_id      String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  course     Course   @relation(fields: [course_id], references: [id])
  modality   Modality @relation(fields: [modality_id], references: [id])
  campaing   Campaing @relation(fields: [campaign_id], references: [id])

  products Product[]
}

model Product {
  id                  String      @id @default(uuid()) @db.Char(36)
  slug                String?
  description         String?
  short_description   String?
  category            String
  edition_id          String
  price               Decimal     @db.Decimal(10, 2)
  discount_price      Decimal?    @db.Decimal(10, 2)
  discount_expires_at DateTime?
  sales_status        SalesStatus @default(DRAFT)
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt

  edition        Edition       @relation(fields: [edition_id], references: [id])
  orders_details OrderDetail[]
}

model Order {
  id           String      @id @default(uuid()) @db.Char(36)
  lead_id      String
  generated_by String?
  sub_total    Decimal     @db.Decimal(10, 2)
  total_amount Decimal     @db.Decimal(10, 2)
  discount     Decimal     @default(0) @db.Decimal(10, 2)
  order_status OrderStatus @default(PENDING)
  order_code   String      @unique @db.Char(7)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  lead   Lead           @relation(fields: [lead_id], references: [id])
  seller SellerProfile? @relation("SELLER_ORDERS", fields: [generated_by], references: [id])

  orderDetails OrderDetail[]
  payments     Payment[]

  // indexes
  @@index([lead_id])
  @@index([order_status])
}

model OrderDetail {
  id            String  @id @default(uuid()) @db.Char(36)
  product_id    String
  price         Decimal @db.Decimal(10, 2)
  order_id      String
  discount_code String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  product    Product  @relation(fields: [product_id], references: [id])
  order      Order    @relation(fields: [order_id], references: [id])
}

model Payment {
  id             String        @id @default(uuid()) @db.Char(36)
  order_id       String
  payment_date   DateTime
  amount         Decimal       @db.Decimal(10, 2)
  payment_method PaymentMethod
  payment_status PaymentStatus
  currency       String?       @db.Char(3)
  transaccion_id String? // from payment gateway
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  order Order @relation(fields: [order_id], references: [id])

  @@index([order_id])
  @@index([payment_status])
}

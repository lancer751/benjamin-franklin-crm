{
  "name": "backend",
  "main": "dist/src/app.js",
  "types": "dist/src/app.d.ts",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/src/client.d.ts",
      "default": "./dist/src/client.js"
    }
  },
  "scripts": {
    "build": "bun run prisma:generate && tsc && tsc-alias",
    "start": "bun run --env-file=.env ./dist/src/app.js",
    "dev": "bun run --hot --env-file=.env src/index.ts",
    "migrate": "bunx prisma migrate dev --name init",
    "reset-db": "bunx prisma migrate reset",
    "show-envs": "bun --print process.env",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "detect-cycles": "madge src --circular",
    "prisma:generate": "bunx prisma generate",
    "prisma:push": "bunx prisma db push",
    "prisma:migrate": "bunx prisma migrate dev --name init",
    "prisma:deploy": "bunx prisma migrate deploy",
    "prisma:seed": "bunx prisma db seed",
    "prisma:studio": "bunx prisma studio",
    "db:reset": "bunx prisma migrate reset",
    "db:setup": "bunx prisma generate && prisma db push && prisma db seed"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "latest",
    "@types/nodemailer": "^7.0.10",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.3.0",
    "jiti": "^2.6.1",
    "madge": "^8.0.0",
    "tsc-alias": "^1.8.16",
    "typescript-eslint": "^8.55.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.6.0",
    "@types/node": "^25.2.3",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "hono": "^4.12.5",
    "nodemailer": "^8.0.1",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "prisma-zod-generator": "^2.1.4",
    "vercel": "^50.32.5",
    "zod": "^4.3.6",
    "shared": "workspace:*"
  }
}

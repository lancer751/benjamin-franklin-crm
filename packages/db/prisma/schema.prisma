generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CursoStatus {
  activo
  inactivo
}

enum OrderStatus {
  PENDING
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  POS
  ONLINE
  YAPE
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum RoleAccess {
  SALES_REP
  MARKETING
  SALES_SUPERVISOR
  ADMIN
  COLLECTIONS
}

enum CampaingStatus {
  ACTIVE
  INACTIVE
  PAUSED
}

enum EditionStatus {
  IN_PROGRESS
  COMPLETED
  OPEN
  SCHEDULED
  DRAFT
  CANCELLED
}

enum SalesStatus {
  DRAFT
  PUBLISHED
  ON_SALE
  COMPLETED
  CANCELLED
}

enum CampaingPlatform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  WEBSITE
}

enum LeadOriginSource {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  WHATSAPP
  WEBSITE
}

enum CampaignMemberStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  ATTEMPTED_CONTACT
  FOLLOW_UP
  ON_HOLD
  WON
  LOST
}

enum Gender {
  MALE
  FEMALE
  NOT_SPECIFIED
}

model Role {
  id          String     @id @default(uuid()) @db.Char(36)
  name        RoleAccess @unique
  description String?
  is_active   Boolean    @default(true)
  users       User[]
}

model Professor {
  id                 String              @id @default(uuid()) @db.Char(36)
  name               String
  lastname           String
  corporate_email    String
  email String @unique
  cellphone          String
  // be careful with this part because if you change the id without requesting the moodle api, an error will appears due to moodle incosistency data.
  moddle_account_id  Int                 @unique
  moodle_user_status MoodleAccountStatus @default(ACTIVE)
  created_at  DateTime              @default(now())
  update_at DateTime @updatedAt

  assigned_editions ProffessorsOnEditions[]
}

model SellerProfile {
  id                     String  @id @default(uuid()) @db.Char(36)
  user_id                String  @unique
  sales_target           Int     @default(0)
  // these fields are filled by the system based on the orders registered and the campaigns assigned to the seller, they are useful for reporting and performance tracking
  total_sales            Int     @default(0)
  total_orders           Int     @default(0)
  completed_orders       Int     @default(0)
  canceled_orders        Int     @default(0)
  return_rate            Decimal @default(0) @db.Decimal(5, 2)
  response_time_avg      Decimal @default(0) @db.Decimal(10, 2) // in seconds
  assigned_supervisor_id String

  user             User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  campaignMembers  CampaignMember[]
  orders           Order[]                @relation("SELLER_ORDERS")
  LeadInteraction  LeadInteraction[]
  assignedCampaing CampaignSeller[]
  // TODO evaluate this and then change the deletion mode of the supervisor relation to SET_NULL
  supervisor       SalesSupervisorProfile @relation(fields: [assigned_supervisor_id], references: [id], onDelete: Cascade)
}

model SalesSupervisorProfile {
  id      String @id @default(uuid()) @db.Char(36)
  user_id String @unique

  // team management
  team_name   String?
  max_sellers Int     @default(10)

  // permissions / supervision scope
  can_assign_leads        Boolean @default(true)
  can_reassign_leads      Boolean @default(true)
  can_approve_discounts   Boolean @default(true)
  can_cancel_orders       Boolean @default(true)
  can_view_all_team_sales Boolean @default(true)

  // approval rules
  discount_limit_percent Decimal  @default(10) @db.Decimal(5, 2)
  max_manual_discount    Decimal? @default(0) @db.Decimal(10, 2) // max discount zamount that the supervisor can apply manually without needing approval from a higher role

  // performance metrics (system-calculated)
  supervised_sellers     Int     @default(0) // how many sellers belong to this supervisor
  active_sellers         Int     @default(0) // how many of those sellers are currently working
  total_team_sales       Int     @default(0)
  total_team_orders      Int     @default(0)
  completed_team_orders  Int     @default(0)
  cancelled_team_orders  Int     @default(0)
  team_conversion_rate   Decimal @default(0) @db.Decimal(5, 2)
  avg_team_response_time Decimal @default(0) @db.Decimal(10, 2) // in seconds

  // team management
  user            User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  assignedSellers SellerProfile[]
}

model CampaignSeller {
  id          String @id @default(uuid()) @db.Char(36)
  campaign_id String
  seller_id   String

  campaign Campaing      @relation(fields: [campaign_id], references: [id])
  seller   SellerProfile @relation(fields: [seller_id], references: [id])

  assigned_at DateTime @default(now())

  @@unique([campaign_id, seller_id])
}

// add more fields for this role
model MarketingProfile {
  id      String @id @default(uuid()) @db.Char(36)
  user_id String @unique

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model User {
  id                  String    @id @default(uuid()) @db.Char(36)
  first_name          String
  middle_name         String
  last_name           String
  email               String    @unique
  corporate_email     String?   @unique
  cellphone           String?   @db.Char(9)
  corporate_cellphone String?   @db.Char(9)
  role_id             String
  is_active           Boolean   @default(true)
  password            String
  birth_date          DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  role            Role                    @relation(fields: [role_id], references: [id])
  marketing       MarketingProfile?
  seller          SellerProfile?
  salesSupervisor SalesSupervisorProfile?
}

enum PhoneType {
  WHATSAPP
  TELEPHONE
}

model LeadPhone {
  id      String    @id @default(uuid()) @db.Char(36)
  number  String
  type    PhoneType
  lead_id String

  lead Lead @relation(fields: [lead_id], references: [id])
}

model CampaignMember {
  id          String               @id @default(uuid()) @db.Char(36)
  lead_id     String
  campaing_id String
  status      CampaignMemberStatus @default(NEW)
  assigned_to String
  source      LeadOriginSource
  created_at  DateTime             @default(now())
  updated_at  DateTime             @updatedAt
  is_primary  Boolean              @default(false)

  lead             Lead              @relation(fields: [lead_id], references: [id])
  campaing         Campaing          @relation(fields: [campaing_id], references: [id])
  seller           SellerProfile?    @relation(fields: [assigned_to], references: [id])
  leadInteractions LeadInteraction[]

  @@unique([lead_id, campaing_id])
  @@index([status])
  @@index([assigned_to])
}

enum LeadStatus {
  ACTIVE
  INACTIVE
}

enum MoodleAccountStatus {
  ACTIVE
  SUSPENDED
}

model CustomerProfile {
  id                 String              @id @default(uuid()) @db.Char(36)
  lead_id            String              @unique
  moodle_user_name   String
  moodle_user_id     Int?                @unique
  moodle_user_status MoodleAccountStatus @default(ACTIVE)
  password           String

  lead Lead @relation(fields: [lead_id], references: [id])
}

model Lead {
  id                  String     @id @default(uuid()) @db.Char(36)
  first_name          String
  middle_name         String
  last_name           String
  profession          String?
  gender              Gender?
  address             String?
  second_address      String?
  email               String     @unique
  secondary_email     String?
  dni                 String?    @unique @db.Char(8)
  lead_status         LeadStatus @default(ACTIVE)
  primary_campaign_id String?
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  //relations
  phones              LeadPhone[]
  orders              Order[]
  interactions        LeadInteraction[]
  campaignsEngaging   CampaignMember[]
  customerProfile     CustomerProfile?
  leadPrimaryCampaing Campaing?         @relation("PrimaryCampaign", fields: [primary_campaign_id], references: [id])
}

enum InteractionType {
  WEBSITE_FORM
  SELL
  WHATSAPP
  EMAIL
  MEETING
  CALL
}

model LeadInteraction {
  id          String          @id @default(uuid()) @db.Char(36)
  lead_id     String
  notes       String
  created_by  String?
  campaing_id String
  type        InteractionType

  lead           Lead           @relation(fields: [lead_id], references: [id])
  campaignMember CampaignMember @relation(fields: [campaing_id], references: [id])
  seller         SellerProfile? @relation(fields: [created_by], references: [id])
}

model Tasks {
  id      String @id @default(uuid()) @db.Char(36)
  title   String
  content String @db.Text()
}

enum CourseType {
  COURSE
  PROGRAM
}

model CourseBenefit {
  id          String  @id @default(uuid()) @db.Char(36)
  course_id   String
  description String
  image_url   String?

  course Course @relation(fields: [course_id], references: [id])
}

model Course {
  id             String     @id @default(uuid()) @db.Char(36)
  type           CourseType
  name           String
  description    String?
  classes_number Int
  image_url      String?
  code           String     @db.Char(7)
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt

  editions Edition[]
  benefits CourseBenefit[]
}

model Campaing {
  id             String           @id @default(uuid()) @db.Char(36)
  campaing_name  String
  initial_budget Decimal          @db.Decimal(10, 2)
  total_spent    Decimal?         @db.Decimal(10, 2)
  status         CampaingStatus
  start_date     DateTime
  end_date       DateTime?
  platform       CampaingPlatform
  is_organic     Boolean
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  product_id     String           @unique

  members        CampaignMember[]
  leads          Lead[]           @relation("PrimaryCampaign")
  relatedProduct Product          @relation(fields: [product_id], references: [id])
  sellers        CampaignSeller[]
}

enum WeekDays {
  LUES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum ScheduleType {
  REGULAR // the default recurring schedule
  OVERRIDE // a temporary schedule for a specific period
}

model EditionSchedule {
  id          String                @id @default(uuid()) @db.Char(36)
  edition_id  String
  day_of_week WeekDays
  type        ScheduleType          @default(REGULAR) // REGULAR applies for the full duration of the edition
  // fields just for OVERRIDE blocks
  valid_from  DateTime?             @db.Date
  valid_until DateTime?             @db.Date
  slots       EditionScheduleSlot[]
  created_at  DateTime              @default(now())
  updated_at  DateTime              @updatedAt

  edition Edition @relation(fields: [edition_id], references: [id])

  @@index([edition_id])
}

model EditionScheduleSlot {
  id          String @id @default(uuid()) @db.Char(36)
  schedule_id String
  start_time  String // "HH:MM" in 24h — avoids timezone drift on TIME columns
  end_time    String // "HH:MM" in 24h

  schedule EditionSchedule @relation(fields: [schedule_id], references: [id], onDelete: Cascade)

  @@index([schedule_id])
}

enum DurationUnit {
  WEEKS
  MONTHS
}

enum Modality {
  PRESENCIAL
  VIRTUAL
  HIBRIDO
  ASINCRONICO
}

model ProffessorsOnEditions {
  professor_id String
  edition_id   String
  assignedAt   DateTime @default(now())

  professors Professor @relation(fields: [professor_id], references: [id])
  editions   Edition   @relation(fields: [edition_id], references: [id])

  @@id([professor_id, edition_id])
}

model Edition {
  id                  String        @id @default(uuid()) @db.Char(36)
  course_id           String
  edition_number      Int
  start_date          DateTime      @db.Date
  hours_amount        Int
  classes_number      Int // you cand define them or take them from the course table
  duration_value      Int
  duration_unit       DurationUnit
  end_date            DateTime      @db.Date
  modality            Modality
  moodle_course_id    Int?          @unique
  meet_link           String? // optional: PACKED modalities do not have one
  whatsapp_group_link String? // optional: PACKED modalities do not have one
  edition_status      EditionStatus @default(DRAFT)
  edition_code        String        @unique @db.Char(13) //generated based on the course-code + year + ednumber

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  course              Course                  @relation(fields: [course_id], references: [id])
  schedules           EditionSchedule[]
  assigned_professors ProffessorsOnEditions[]
  ownedProduct        Product?
}

model Category {
  id         String    @id @default(uuid()) @db.Char(36)
  name       String    @unique
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  products   Product[]
}

model Product {
  id                      String      @id @default(uuid()) @db.Char(36)
  name                    String // you can write a new name or define it from the course and edition.
  slug                    String?
  description             String?
  image_url               String? // optional, you can take it from the course or edition or write a new one
  short_description       String?
  presale_price           Decimal?    @db.Decimal(10, 2)
  edition_id              String      @unique
  category_id             String
  installments_max_number Int
  installments_min_number Int
  discount_price          Decimal?    @default(0) @db.Decimal(10, 2)
  discount_expires_at     DateTime?
  sales_status            SalesStatus @default(DRAFT)
  created_at              DateTime    @default(now())
  updated_at              DateTime    @updatedAt

  orders_details OrderDetail[]
  edition        Edition        @relation(fields: [edition_id], references: [id])
  prices         ProductPrice[]
  category       Category       @relation(fields: [category_id], references: [id])
  campaing       Campaing?
}

enum AttendanceMode {
  VIRTUAL
  PRESENCIAL
  HEREDADO
}

model ProductPrice {
  id                String         @id @default(uuid()) @db.Char(36)
  product_id        String
  attendance_mode   AttendanceMode // select between virtual or presencial when the edition has a HIBRID modalitity in frontend if not take the attendance mode from the edition modality and set it to the price
  cash_price        Decimal        @db.Decimal(10, 2)
  installment_price Decimal        @db.Decimal(10, 2)
  enrollment_fee    Decimal        @db.Decimal(10, 2) // amount to pay if the lead wants to enroll to an edition and pay later the full price

  product Product @relation(fields: [product_id], references: [id])

  @@unique([product_id, attendance_mode])
}

model Order {
  id           String  @id @default(uuid()) @db.Char(36)
  lead_id      String
  generated_by String? // seller that created the order, optional because it can be generated by the system when a lead enrolls to an edition from the website
  sub_total    Decimal @db.Decimal(10, 2)
  total_amount Decimal @db.Decimal(10, 2)
  // be carefull with those fields, they can be easily desynchronized in the frontend, therefore the backend should check these imputs out before creating the order

  discount     Decimal?    @default(0) @db.Decimal(10, 2) // optional because sellers needs approval to apply discounts
  order_status OrderStatus @default(PENDING) // the seller doesn't have to update this field, it will be updated by the system based on the payments registered and the payment plan if it applies
  order_code   String      @unique @db.Char(7) // generated randomly by the frontend but should be checked in the backend to avoid duplicates

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  lead   Lead           @relation(fields: [lead_id], references: [id])
  seller SellerProfile? @relation("SELLER_ORDERS", fields: [generated_by], references: [user_id])

  orderDetails OrderDetail[]
  paymentPlans PaymentPlan[]
  payments     Payment[]

  // indexes
  @@index([lead_id])
  @@index([order_status])
}

model OrderDetail {
  id            String  @id @default(uuid()) @db.Char(36)
  product_id    String
  price         Decimal @db.Decimal(10, 2)
  order_id      String
  discount_code String? @db.Char(7)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  product    Product  @relation(fields: [product_id], references: [id])
  order      Order    @relation(fields: [order_id], references: [id])
}

enum PaymentType {
  FULL
  INSTALLMENTS
}

//regiter payment transactions
model Payment {
  id                   String        @id @default(uuid()) @db.Char(36)
  order_id             String
  scheduled_payment_id String?
  payment_date         DateTime
  amount               Decimal       @db.Decimal(10, 2)
  payment_method       PaymentMethod
  payment_status       PaymentStatus
  type                 PaymentType
  payment_receipt      String?
  currency             String?       @db.Char(3)
  transaccion_id       String? // from payment gateway
  created_at           DateTime      @default(now())
  updated_at           DateTime      @updatedAt

  schedulePayment ScheduledPayment? @relation(fields: [scheduled_payment_id], references: [id])
  order           Order             @relation(fields: [order_id], references: [id])

  @@index([payment_status])
}

enum PaymentPlanStatus {
  COMPLETED
  PENDING
  CANCELLED
}

model PaymentPlan {
  id                 String            @id @default(uuid()) @db.Char(36)
  total_installments Int
  order_id           String
  total_amount       Decimal           @db.Decimal(10, 2)
  start_date         DateTime
  status             PaymentPlanStatus @default(PENDING)

  order        Order              @relation(fields: [order_id], references: [id])
  installments ScheduledPayment[]

  @@index([order_id])
}

enum InstallmentStatus {
  PAID
  OVERDUE
  PENDING
}

model ScheduledPayment {
  id              String            @id @default(uuid()) @db.Char(36)
  due_date        DateTime
  due_amount      Decimal           @db.Decimal(10, 2)
  payment_plan_id String
  number          Int
  status          InstallmentStatus @default(PENDING)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  payment_plan PaymentPlan @relation(fields: [payment_plan_id], references: [id])
  payments     Payment[]

  @@unique([payment_plan_id, number])
}

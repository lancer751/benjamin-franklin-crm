{
  "name": "moodle-enroll-manager",
  "version": "0.0.1",
  "description": "",
  "packageManager": "bun@1.2.4",
  "workspaces": [
    "./backend",
    "./management-dashboard",
    "./shared",
    "moodle-enrollment-studio",
    "./packages/**"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:client": "turbo dev --filter=management-dashboard",
    "dev:server": "turbo dev --filter=backend",
    "build": "turbo build",
    "build:client": "turbo build --filter=management-dashboard",
    "build:studio": "turbo build --filter=moodle-enrollment-studio",
    "build:server": "turbo build --filter=backend",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "postinstall": "turbo build --filter=@repo/database --filter=shared --filter=backend"
  },
  "author": "lauwc",
  "license": "ISC",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/pg": "^8.20.0",
    "bun-types": "latest",
    "rolldown": "^1.0.3",
    "turbo": "^2.6.3",
    "vite": "^8.0.14"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
---
import { GraduationCap } from "@lucide/astro";

const nav = [
  { to: "/", label: "Inicio" },
  { to: "/nosotros", label: "Nosotros" },
  { to: "/cursos", label: "Cursos" },
  { to: "/programas", label: "Programas" },
];
---

<header
  class="sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur"
>
  <div class="container-wide flex h-16 items-center justify-between gap-6">
    <a
      href="/"
      class="flex items-center gap-2 font-display text-xl font-bold text-navy"
    >
      <span
        class="grid h-9 w-9 place-items-center rounded-md bg-navy text-primary-foreground"
      >
        <GraduationCap class="h-5 w-5" />
      </span>
      <span class="leading-tight">
        Benjamín<br class="hidden sm:block" />
        <span class="text-brand-red">Franklin</span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 md:flex">
      {
        nav.map((n) => (
          <a
            href={n.to}
            class="text-sm font-medium text-foreground/80 transition-colors hover:text-navy"
          >
            {n.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/contacto"
        class="hidden rounded-md btn-cta px-4 py-2 text-sm font-semibold sm:inline-flex"
      >
        Contacto
      </a>
      <button class="md:hidden" aria-label="Menú"> d </button>
    </div>
  </div>
</header>
